# =============================================================================
# ResuMAI — Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================================

# --- App URL (required for Vercel queue triggers) ---
# Set to your production URL on Vercel, or http://localhost:3000 locally
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database (Neon PostgreSQL) ---
# Get from: https://neon.tech → your project → Connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Clerk Authentication ---
# Get from: https://clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Clerk webhook secret (from Clerk Dashboard → Webhooks → your endpoint)
CLERK_WEBHOOK_SECRET=whsec_...

# --- OpenAI ---
# Get from: https://platform.openai.com → API Keys
OPENAI_API_KEY=sk-...
# Optional: override default model (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# --- Upstash Redis (queue + rate limiting) ---
# Get from: https://upstash.com → your Redis database → REST API
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# --- Internal API Security ---
# Any random secret string — used to protect the internal queue processor route
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=change-me-to-a-random-secret

# --- Vercel Cron Security ---
# Set in Vercel dashboard too — used to authenticate cron job calls
# Generate with: openssl rand -hex 32
CRON_SECRET=change-me-to-a-random-secret

# --- Stripe (optional — for paid plans) ---
# Get from: https://stripe.com → Developers → API Keys
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...
